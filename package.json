{
  "name": "agent-harness-public-template-v6",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"pnpm dev:api\" \"pnpm dev:web\"",
    "dev:web": "pnpm --filter @repo/web dev",
    "dev:api": "pnpm --filter @repo/api dev",
    "build:web": "pnpm --filter @repo/web build",
    "build:api": "pnpm --filter @repo/api build",
    "start:web": "pnpm --filter @repo/web start",
    "start:api": "pnpm --filter @repo/api start",
    "lint": "bash scripts/lint-js.sh",
    "format": "bash scripts/format-js.sh",
    "typecheck": "tsc -p apps/web/tsconfig.json --noEmit && tsc -p apps/api/tsconfig.json --noEmit && tsc -p packages/domain/tsconfig.json --noEmit && tsc -p packages/app/tsconfig.json --noEmit && tsc -p packages/data/tsconfig.json --noEmit && tsc -p packages/integrations/tsconfig.json --noEmit && tsc -p packages/shared/tsconfig.json --noEmit && tsc -p packages/schema/tsconfig.json --noEmit && tsc -p packages/ui/tsconfig.json --noEmit",
    "test:smoke": "playwright test tests/e2e/smoke.spec.ts",
    "check:docs": "python3 scripts/check_doc_freshness.py",
    "test:unit": "vitest run --passWithNoTests",
    "check:deps": "depcruise --config .dependency-cruiser.cjs packages/ apps/",
    "check:architecture": "python3 scripts/check_architecture.py",
    "check:harness": "python3 scripts/verify_harness_state.py",
    "check:agents": "python3 scripts/verify_agents.py",
    "check:no-skips": "python3 scripts/verify_no_skipped_tests.py",
    "check:route-coverage": "python3 scripts/verify_route_coverage.py",
    "check:root": "python3 scripts/verify_root_hygiene.py",
    "test:scripts": "python3 -m pytest tests/scripts/ -v",
    "check:secrets": "secretlint \"**/*.{ts,tsx,js,jsx,json,yml,yaml,env,md,sh,toml}\"",
    "check:security": "bash scripts/review-security.sh",
    "check:runtime": "bash scripts/dev-smoke.sh",
    "quick-check": "bash scripts/quick-check.sh",
    "check": "bash scripts/check.sh",
    "new:work-item": "bash scripts/new-work-item.sh",
    "prepare": "bash scripts/install-hooks.sh"
  },
  "devDependencies": {
    "@biomejs/biome": "latest",
    "@playwright/test": "latest",
    "@react-router/dev": "latest",
    "@secretlint/core": "11.4.1",
    "@secretlint/secretlint-rule-preset-recommend": "11.4.1",
    "@tailwindcss/vite": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "concurrently": "^9.2.1",
    "dependency-cruiser": "^17.3.10",
    "lefthook": "latest",
    "playwright": "latest",
    "react": "latest",
    "react-dom": "latest",
    "secretlint": "11.4.1",
    "tailwindcss": "latest",
    "tsx": "latest",
    "typescript": "~5.8.3",
    "vite": "~7.0.8",
    "vitest": "^4.1.2"
  }
}
